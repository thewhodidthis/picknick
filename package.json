{
  "name": "picknick",
  "version": "1.0.4",
  "description": "Helps select things",
  "keywords": [
    "gallery",
    "menu",
    "slides",
    "tabs"
  ],
  "jsnext:main": "index.js",
  "main": "dist/picknick.mjs",
  "homepage": "https://github.com/thewhodidthis/picknick#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thewhodidthis/picknick.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/picknick/issues"
  },
  "directories": {
    "example": "example"
  },
  "config": {
    "jscsrc": ".jscsrc",
    "remote": "thewhodidthis@umfufu:www/example/picknick/"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clear": "npm run clear:dist && npm run clear:logs",
    "clear:dist": "rm -rf dist/",
    "clear:logs": "rm -f *.log",
    "lint": "npm run lint:es && npm run lint:js",
    "lint:es": "eslint index.js",
    "prelint:js": "npm run build",
    "lint:js": "(js=dist/picknick.mjs; jshint $js; jscs $js --reporter=inline) 2>&1 | sed '/^s*$/d' | tee out.log",
    "postlint:js": "find out.log -size 0 -print0 | xargs -0 rm",
    "start": "npm run watch",
    "watch": "rollup -c -w",
    "preexample": "npm run build",
    "example": "npm run example:link && npm run example:serve",
    "example:link": "ln -siv \"$(pwd)/dist/picknick.min.js\" example/picknick.js",
    "example:push": "rsync -avruzLPC --exclude=.DS_Store ./example/ $npm_package_config_remote",
    "example:serve": "php -S localhost:8000 -t example/",
    "prebuild": "mkdir -p dist/",
    "build": "rollup -c",
    "build:min": "uglifyjs dist/picknick.js -cm > dist/picknick.min.js",
    "postbuild": "npm run build:min",
    "preversion": "npm run clear && npm run build"
  },
  "engines": {
    "node": ">=4.2.4",
    "npm": ">=3.5.3"
  },
  "dependencies": {},
  "devDependencies": {
    "babel-eslint": "latest",
    "babel-preset-es2015": "latest",
    "eslint": "latest",
    "eslint-plugin-import": "latest",
    "eslint-config-airbnb-base": "latest",
    "jscs": "latest",
    "jshint": "latest",
    "rollup": "latest",
    "rollup-plugin-babel": "latest",
    "rollup-watch": "latest",
    "uglify-js": "latest"
  },
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (https://www.thewhodidthis.com)",
  "license": "Unlicense"
}
