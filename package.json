{
  "name": "picknick",
  "version": "0.0.8",
  "description": "Helps select things",
  "author": "sChzs BkgNns <sotirios.bakagiannis@gmail.com> (http://thewhodidthis.com/)",
  "homepage": "https://github.com/thewhodidthis/picknick",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\"",
    "clean": "npm run clean:dist && npm run clean:logs",
    "clean:dist": "rm -rf dist/",
    "clean:logs": "rm -f *.log",
    "lint": "(jshint index.js & jscs index.js --reporter=inlinesingle) 2>&1 | tee out.log",
    "postlint": "find out.log -size 0 -print0 | xargs -0 rm",
    "start": "npm run build && npm run build:min",
    "prebuild": "mkdir -p dist/",
    "build": "browserify index.js -s picknick > ./dist/picknick.js",
    "build:min": "browserify index.js -s picknick | uglifyjs -o ./dist/picknick.min.js",
    "preversion": "npm run clean:logs"
  },
  "config": {
    "jscsrc": ".jscsrc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thewhodidthis/picknick.git"
  },
  "bugs": {
    "url": "https://github.com/thewhodidthis/picknick/issues"
  },
  "directories": {
    "example": "example"
  },
  "keywords": [
    "menu",
    "tabs",
    "slides",
    "gallery"
  ],
  "engines": {
    "node": ">=0.11.0",
    "npm": ">=2.0.0"
  },
  "devDependencies": {
    "jscs": "latest",
    "jshint": "latest",
    "uglify-js": "latest",
    "browserify": "latest"
  },
  "license": "Unlicense"
}
